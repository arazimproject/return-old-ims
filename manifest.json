{
  "manifest_version": 3,
  "name": "Return Old IMS",
  "version": "1.0",
  "description": "Return the beloved old IMS website.",
  "icons": {
    "16": "icon/icon-16.png",
    "32": "icon/icon-32.png",
    "48": "icon/icon-48.png",
    "128": "icon/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://ims.tau.ac.il/TalSSO/Sys/Main.aspx*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "new_sidebar.html"
      ],
      "matches": [
        "*://ims.tau.ac.il/*"
      ]
    }
  ]
}